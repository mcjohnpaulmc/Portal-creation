# -----------------------------------------------------------------------
# SPC — Solutions Portal & Collaterals
# -----------------------------------------------------------------------

# -----------------------------------------------------------------------
# OPENAI
# -----------------------------------------------------------------------
# Required for AI-powered collateral generation, project metadata, and hero copy.
# Uses gpt-4o-mini by default. Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-..."

# -----------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------
# Port the Express server listens on. Defaults to 4567 if not set.
PORT=4567

# App base URL (used for self-referential links / OAuth callbacks)
APP_URL="http://localhost:4567"

# -----------------------------------------------------------------------
# GOOGLE DRIVE INTEGRATION
# -----------------------------------------------------------------------
# Absolute or relative path to your Service Account JSON key file.
# The service account must have "Editor" access on the shared Drive folder.
# Example: ./keys/spc-service-account.json
GOOGLE_SERVICE_ACCOUNT_KEY_FILE="./keys/service-account.json"

# The ID of the shared Google Drive folder where SPC data is stored.
# Get this from the folder URL: drive.google.com/drive/folders/<FOLDER_ID>
#
# SPC creates this structure inside the folder automatically:
#   <FOLDER>/
#     SPC/
#       data-store.json        ← full database backup
#       solutions/<id>/        ← one folder per solution
#         metadata.json
#       collaterals/<id>/      ← one folder per collateral
#         metadata.json
#         <uploaded-files>
#       logs/
#         portal-logs.csv      ← append-only audit log
GOOGLE_DRIVE_FOLDER_ID="0AN1QHfCnyQl-Uk9PVA"
